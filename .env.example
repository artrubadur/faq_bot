PATHS__LOGGING="./config/logging.prod.yml"
PATHS__CONSTANTS="./config/constants.example.yml"
PATHS__MESSAGES="./config/messages.example.yml"
PATHS__COMMANDS="./config/commands.example.yml"
PATHS__REQUESTS="./config/requests.yandex.yml"

BOT__TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
BOT__ADMINS=[123456789]

DB__NAME="faq_bot_db"
DB__USER="postgres"
DB__PASSWORD="password"
DB__HOST="localhost"

REDIS__HOST="localhost"
REDIS__PASSWORD="password"
REDIS__LONG_TTL=86400
REDIS__SHORT_TTL=300

REQUESTS__FOLDER_ID="YOUR_FOLDER_ID"
REQUESTS__IAM_TOKEN="YOUR_IAM_TOKEN"

RATE_LIMIT__ENABLED=true
RATE_LIMIT__MAX_REQUESTS=5
RATE_LIMIT__WINDOW=10
RATE_LIMIT__SKIP_ADMIN=true

QUESTIONS__SIMILAREST_THRESHOLD=0.7
QUESTIONS__SIMILAR_THRESHOLD=0.4
QUESTIONS__MAX_SIMILAR_AMOUNT=7
QUESTIONS__MAX_POPULAR_AMOUNT=7
QUESTIONS__MAX_AMOUNT=7

DB_SCHEMA__QUESTION_TEXT_MAX_LEN=384
DB_SCHEMA__ANSWER_TEXT_MAX_LEN=384
DB_SCHEMA__QUESTION_EMBEDDING_DIM=256
